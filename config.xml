<?xml version='1.0' encoding='utf-8'?>
<widget id="io.cordova.hellocordova" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>HelloCordova</name>
    <description>Sample Apache Cordova App</description>
    <author email="dev@cordova.apache.org" href="https://cordova.apache.org">
        Apache Cordova Team
    </author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    
    <!-- Permissions pour la géolocalisation -->
    <allow-intent href="geo:*" />

    <!-- Configuration des icÃ´nes -->
    <icon src="www/img/gigachad.jpg" platform="android" width="57" height="57" density="mdpi"/>
    
    <!-- PrÃ©fÃ©rences pour le splashscreen moderne (Android 12+) -->
    <preference name="AndroidWindowSplashScreenAnimatedIcon" value="www/img/meme_soldier_stare.png" />
    <preference name="AndroidWindowSplashScreenBackground" value="#ff0000ff" />
    <preference name="SplashScreenDelay" value="3000" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    
    <!-- PrÃ©fÃ©rences pour les versions Android antÃ©rieures -->
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="ShowSplashScreenSpinner" value="false" />
</widget>