# OpenAI API Configuration
# IMPORTANT : Ne JAMAIS committer ce fichier avec la vraie clé !
# Copiez ce fichier en .env et remplacez par votre vraie clé

OPENAI_API_KEY=sk-VOTRE_NOUVELLE_CLE_API_ICI

# Port du serveur proxy (optionnel, par défaut 3000)
PORT=3000

# Environment (development / production)
NODE_ENV=development

# Logs (optionnel)
LOG_LEVEL=info

